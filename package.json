{
  "name": "@unitydynamics/application-platform-components",
  "version": "0.1.0",
  "description": "Shared UI components for the Unity Dynamics Application Platform.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0",
    "react-i18next": "^15.1.0",
    "i18next": "^24.2.1",
    "zustand": "^4.5.7"
  },
  "dependencies": {
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.536.0",
    "react-day-picker": "^9.10.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@changesets/changelog-git": "^0.2.1",
    "@changesets/cli": "^2.29.0",
    "@storybook/addon-essentials": "8.6.17",
    "@storybook/addon-interactions": "8.6.17",
    "@storybook/addon-links": "8.6.17",
    "@storybook/react-vite": "8.6.17",
    "@storybook/test": "8.6.17",
    "@testing-library/react": "^16.0.0",
    "storybook": "8.6.17",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "i18next": "^24.2.1",
    "jsdom": "^25.0.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^15.1.0",
    "tailwindcss": "^4.1.11",
    "@tailwindcss/vite": "^4.1.11",
    "tailwindcss-rtl": "^0.9.0",
    "tsup": "^8.3.0",
    "typescript": "^5.8.3",
    "vitest": "^2.0.5",
    "@vitest/coverage-v8": "^2.0.5",
    "zustand": "^4.5.7"
  },
  "packageManager": "pnpm@9.12.0"
}
